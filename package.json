{
    "bin": {"snapcode": "jdeploy-bundle/jdeploy.js"},
    "author": "ReportMill Software, Inc.",
    "name": "snapcodejava",
    "description": "A Java IDE for education",
    "files": ["jdeploy-bundle"],
    "main": "index.js",
    "preferGlobal": true,
    "scripts": {"test": "echo \"Error: no test specified\" && exit 1"},
    "version": "2026.3.12",
    "jdeploy": {
        "jdk": true,
        "fallbackToUniversal": false,
        "publishTargets": [{
            "name": "github: github",
            "type": "GITHUB",
            "url": "https://github.com/reportmill/SnapCode"
        }],
        "javaVersion": "25",
        "documentTypes": [{
            "editor": true,
            "extension": "java",
            "mimetype": "text/java"
        }],
        "jar": "build/libs/SnapCodeAll-2026.03.jar",
        "title": "SnapCode",
        "downloadPage": {"platforms": ["all"]},
        "platformBundlesEnabled": false
    },
    "dependencies": {
        "command-exists-promise": "^2.0.2",
        "node-fetch": "2.6.7",
        "tar": "^4.4.8",
        "yauzl": "^2.10.0",
        "shelljs": "^0.8.4"
    },
    "homepage": "https://reportmill.com/SnapCode"
}